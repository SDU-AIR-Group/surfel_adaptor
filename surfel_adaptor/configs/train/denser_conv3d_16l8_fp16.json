{
    "models": {
        "denser": {
            "name": "StructureDenser",
            "args": {
                "in_channels": 1,
                "out_channels": 1,
                "latent_channels": 8,
                "num_res_blocks": 2,
                "num_res_blocks_middle": 2,
                "channels": [16, 64, 128],
                "use_fp16": true
            }
        }
    },
    "dataset": {
        "name": "StructureDenser",
        "args": {
            "resolution": 128,
            "min_aesthetic_score": 4.5
        }
    },
    "trainer": {
        "name": "StructureDenserVaeTrainer",
        "args": {
            "max_steps": 1000000,
            "batch_size_per_gpu": 2,
            "batch_split": 1,
            "optimizer": {
                "name": "AdamW",
                "args": {
                    "lr": 1e-5,
                    "weight_decay": 0.0
                }
            },
            "ema_rate": [
                0.9999
            ],
            "fp16_mode": "inflat_all",
            "fp16_scale_growth": 0.0001,
            "grad_clip": {
                "name": "AdaptiveGradClipper",
                "args": {
                    "max_norm": 50.0,
                    "clip_percentile": 95
                }
            },
            "i_log": 100,
            "i_sample": 10000,
            "i_save": 10000,
            "loss_type": "dice",
            "lambda_kl": 0.001
        }
    }
}